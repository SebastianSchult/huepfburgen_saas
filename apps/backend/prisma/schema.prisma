generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TenantPlan {
  basic
  pro
  business
}

enum TenantStatus {
  active
  suspended
  cancelled
}

enum UserRole {
  owner
  admin
  staff
  viewer
  super_admin
}

enum UserStatus {
  invited
  active
  disabled
}

enum CustomerType {
  private
  business
}

enum EquipmentStatus {
  available
  reserved
  maintenance
  inactive
}

enum BookingStatus {
  draft
  requested
  confirmed
  in_progress
  completed
  cancelled
}

enum PlatformAdminRole {
  super_admin
  support_admin
  billing_admin
  read_only_support
}

enum PlatformAdminStatus {
  active
  disabled
}

enum SupportSessionStatus {
  active
  ended
  expired
}

model Tenant {
  id        String       @id @default(uuid()) @db.Uuid
  name      String
  slug      String       @unique
  plan      TenantPlan   @default(basic)
  status    TenantStatus @default(active)
  createdAt DateTime     @default(now()) @map("created_at")
  updatedAt DateTime     @updatedAt @map("updated_at")

  users                   User[]
  locations               Location[]
  equipmentCategories     EquipmentCategory[]
  equipment               Equipment[]
  customers               Customer[]
  bookings                Booking[]
  bookingItems            BookingItem[]
  equipmentUnavailability EquipmentUnavailability[]
  supportSessions         SupportSession[]
  auditLogs               AuditLog[]

  @@map("tenants")
}

model User {
  id           String     @id @default(uuid()) @db.Uuid
  tenantId     String     @map("tenant_id") @db.Uuid
  firstName    String     @map("first_name")
  lastName     String     @map("last_name")
  email        String     @unique
  passwordHash String     @map("password_hash")
  role         UserRole   @default(staff)
  status       UserStatus @default(active)
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")

  tenant             Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdBookings    Booking[]        @relation("created_by_user")
  supportSessions    SupportSession[] @relation("target_user")

  @@index([tenantId])
  @@map("users")
}

model Location {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String   @map("tenant_id") @db.Uuid
  name        String
  street      String?
  houseNumber String?  @map("house_number")
  postalCode  String?  @map("postal_code")
  city        String?
  notes       String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  tenant    Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  equipment Equipment[]

  @@index([tenantId])
  @@map("locations")
}

model EquipmentCategory {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String   @map("tenant_id") @db.Uuid
  name        String
  description String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  tenant    Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  equipment Equipment[]

  @@unique([tenantId, name])
  @@index([tenantId])
  @@map("equipment_categories")
}

model Equipment {
  id           String          @id @default(uuid()) @db.Uuid
  tenantId     String          @map("tenant_id") @db.Uuid
  categoryId   String?         @map("category_id") @db.Uuid
  locationId   String?         @map("location_id") @db.Uuid
  name         String
  description  String?
  sku          String?
  serialNumber String?         @map("serial_number")
  status       EquipmentStatus @default(available)
  imageUrl     String?         @map("image_url")
  active       Boolean         @default(true)
  createdAt    DateTime        @default(now()) @map("created_at")
  updatedAt    DateTime        @updatedAt @map("updated_at")

  tenant         Tenant                   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  category       EquipmentCategory?       @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  location       Location?                @relation(fields: [locationId], references: [id], onDelete: SetNull)
  bookingItems   BookingItem[]
  unavailability EquipmentUnavailability[]

  @@unique([tenantId, sku])
  @@index([tenantId])
  @@index([tenantId, status])
  @@map("equipment")
}

model Customer {
  id          String       @id @default(uuid()) @db.Uuid
  tenantId    String       @map("tenant_id") @db.Uuid
  type        CustomerType @default(private)
  companyName String?      @map("company_name")
  firstName   String?      @map("first_name")
  lastName    String?      @map("last_name")
  email       String?
  phone       String?
  street      String?
  houseNumber String?      @map("house_number")
  postalCode  String?      @map("postal_code")
  city        String?
  notes       String?
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")

  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  bookings Booking[]

  @@index([tenantId])
  @@index([tenantId, type])
  @@map("customers")
}

model Booking {
  id              String        @id @default(uuid()) @db.Uuid
  tenantId        String        @map("tenant_id") @db.Uuid
  customerId      String        @map("customer_id") @db.Uuid
  bookingNumber   String        @map("booking_number")
  startDate       DateTime      @map("start_date") @db.Date
  endDate         DateTime      @map("end_date") @db.Date
  status          BookingStatus @default(draft)
  subtotalAmount  Decimal       @default(0) @map("subtotal_amount") @db.Decimal(10, 2)
  depositAmount   Decimal       @default(0) @map("deposit_amount") @db.Decimal(10, 2)
  totalAmount     Decimal       @default(0) @map("total_amount") @db.Decimal(10, 2)
  notes           String?
  createdByUserId String?       @map("created_by_user_id") @db.Uuid
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")

  tenant        Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customer      Customer     @relation(fields: [customerId], references: [id], onDelete: Restrict)
  createdByUser User?        @relation("created_by_user", fields: [createdByUserId], references: [id], onDelete: SetNull)
  bookingItems  BookingItem[]

  @@unique([tenantId, bookingNumber])
  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, startDate, endDate])
  @@map("bookings")
}

model BookingItem {
  id         String   @id @default(uuid()) @db.Uuid
  tenantId   String   @map("tenant_id") @db.Uuid
  bookingId  String   @map("booking_id") @db.Uuid
  equipmentId String  @map("equipment_id") @db.Uuid
  quantity   Int      @default(1)
  unitPrice  Decimal  @default(0) @map("unit_price") @db.Decimal(10, 2)
  lineTotal  Decimal  @default(0) @map("line_total") @db.Decimal(10, 2)
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  tenant    Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  booking   Booking   @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  equipment Equipment @relation(fields: [equipmentId], references: [id], onDelete: Restrict)

  @@index([tenantId])
  @@index([bookingId])
  @@index([equipmentId])
  @@map("booking_items")
}

model EquipmentUnavailability {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String   @map("tenant_id") @db.Uuid
  equipmentId String   @map("equipment_id") @db.Uuid
  startDate   DateTime @map("start_date") @db.Date
  endDate     DateTime @map("end_date") @db.Date
  reason      String
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  tenant    Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  equipment Equipment @relation(fields: [equipmentId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([equipmentId, startDate, endDate])
  @@map("equipment_unavailability")
}

model PlatformAdmin {
  id           String              @id @default(uuid()) @db.Uuid
  email        String              @unique
  passwordHash String              @map("password_hash")
  role         PlatformAdminRole
  status       PlatformAdminStatus @default(active)
  createdAt    DateTime            @default(now()) @map("created_at")
  updatedAt    DateTime            @updatedAt @map("updated_at")

  supportSessions SupportSession[]

  @@map("platform_admins")
}

model SupportSession {
  id              String               @id @default(uuid()) @db.Uuid
  platformAdminId String               @map("platform_admin_id") @db.Uuid
  tenantId        String               @map("tenant_id") @db.Uuid
  targetUserId    String?              @map("target_user_id") @db.Uuid
  reason          String
  startedAt       DateTime             @default(now()) @map("started_at")
  expiresAt       DateTime             @map("expires_at")
  endedAt         DateTime?            @map("ended_at")
  status          SupportSessionStatus @default(active)

  platformAdmin PlatformAdmin @relation(fields: [platformAdminId], references: [id], onDelete: Restrict)
  tenant        Tenant        @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  targetUser    User?         @relation("target_user", fields: [targetUserId], references: [id], onDelete: SetNull)

  @@index([platformAdminId])
  @@index([tenantId])
  @@index([status, expiresAt])
  @@map("support_sessions")
}

model AuditLog {
  id         String   @id @default(uuid()) @db.Uuid
  actorType  String   @map("actor_type")
  actorId    String   @map("actor_id")
  tenantId   String?  @map("tenant_id") @db.Uuid
  action     String
  entityType String   @map("entity_type")
  entityId   String?  @map("entity_id")
  metadata   Json?    @map("metadata_json")
  createdAt  DateTime @default(now()) @map("created_at")

  tenant Tenant? @relation(fields: [tenantId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([actorType, actorId])
  @@index([action, createdAt])
  @@map("audit_logs")
}
